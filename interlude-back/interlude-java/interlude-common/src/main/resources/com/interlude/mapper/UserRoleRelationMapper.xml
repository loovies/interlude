<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interlude.mapper.UserRoleRelationMapper">
	<!--实体映射-->
	<resultMap id="base_result_map" type="com.interlude.entity.po.UserRoleRelation">
		<!--关联ID-->
		<id column="id" property="id"/>
		<!--用户ID-->
		<result column="user_id" property="userId"/>
		<!--角色ID-->
		<result column="role_id" property="roleId"/>
	</resultMap>
	<!--通用测序结果列-->
	<sql id="base_column_list">
		id,user_id,role_id
	</sql>


	<!--基础条件查询-->
	<sql id="base_query_condition">
		<if test="query.id != null">
			and id = #{query.id} 
		</if>
		<if test="query.userId != null and query.userId != ''">
			and user_id = #{query.userId} 
		</if>
		<if test="query.roleId != null">
			and role_id = #{query.roleId} 
		</if>
	</sql>

	<!--扩展的条件查询-->
	<sql id="base_query_condition_extend">
		<if test="query.userIdFuzzy != null and query.userIdFuzzy != ''">
			and user_id like concat('%', #{query.userIdFuzzy}, '%')
		</if>
	</sql>

	<!--扩展的查询条件-->
	<sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
	</sql>

	<!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM user_role_relation <include refid="query_condition"/>
		<if test="query.orderBy != null"> order by ${query.orderBy} </if>
		<if test="query.simplePage != null"> limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>

	<!--查询数量-->
	<select id="selectCount" resultType="java.lang.Integer">
		SELECT count(1) FROM user_role_relation <include refid="query_condition"/>
	</select>

	<!--插入(匹配有值的字段)-->
	<insert id="insert" parameterType="com.interlude.entity.po.UserRoleRelation">
		<selectKey keyProperty = "bean.id" resultType = "Integer" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>		INSERT INTO user_role_relation
		<trim  prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id != null">
				id,
			</if>
			<if test="bean.userId != null">
				user_id,
			</if>
			<if test="bean.roleId != null">
				role_id,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.id != null">
				#{bean.id},
			</if>
			<if test="bean.userId != null">
				#{bean.userId},
			</if>
			<if test="bean.roleId != null">
				#{bean.roleId},
			</if>
		</trim>
	</insert>

	<!-- 插入或者更新 (匹配有值的字段) -->
	<insert id="insertOrUpdate" parameterType="com.interlude.entity.po.UserRoleRelation">
		INSERT INTO user_role_relation
		<trim  prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id != null">
				id,
			</if>
			<if test="bean.userId != null">
				user_id,
			</if>
			<if test="bean.roleId != null">
				role_id,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.id != null">
				#{bean.id},
			</if>
			<if test="bean.userId != null">
				#{bean.userId},
			</if>
			<if test="bean.roleId != null">
				#{bean.roleId},
			</if>
		</trim>
		on DUPLICATE key update
		<trim  prefix="" suffix="" suffixOverrides=",">

			<if test="bean.userId!=null">
				user_id = VALUES(user_id),
			</if>
			<if test="bean.roleId!=null">
				role_id = VALUES(role_id),
			</if>
		</trim>
	</insert>

	<!--添加 (批量插入)-->
	<insert id="insertBatch" parameterType="com.interlude.entity.po.UserRoleRelation" >
		INSERT INTO user_role_relation(user_id,role_id)values
		<foreach collection="list" item="item" separator=",">
			(#{item.userId},#{item.roleId})
		</foreach>
	</insert>

	<!--批量插入或者更新-->
	<insert id="insertOrUpdateBatch" parameterType="com.interlude.entity.po.UserRoleRelation" >
		INSERT INTO user_role_relation(user_id,role_id)values
		<foreach collection="list" item="item" separator=",">
			(#{item.userId},#{item.roleId})
		</foreach>
		on DUPLICATE key update
		id = VALUES(id),user_id = VALUES(user_id),role_id = VALUES(role_id)
	</insert>

	<!-- 根据Id查询 -->
	<select id="selectById" resultMap="base_result_map">
		select <include refid="base_column_list"/> from user_role_relation where id=#{id}
	</select>

	<select id="selectByUserId" resultMap="base_result_map">
		select <include refid="base_column_list"/> from user_role_relation where user_id=#{userId}
	</select>

	<!-- 根据Id更新 -->
	<update id="updateById" parameterType="com.interlude.entity.po.UserRoleRelation">
		update user_role_relation
		<set>
			<if test="bean.id != null" >
				id = #{bean.id},
			</if>
			<if test="bean.userId != null" >
				user_id = #{bean.userId},
			</if>
			<if test="bean.roleId != null" >
				role_id = #{bean.roleId},
			</if>

		</set>
		where id=#{id}
	</update>

	<!-- 根据Id删除 -->
	<delete id="deleteById">
		delete from user_role_relation where id=#{id}
	</delete>

</mapper>