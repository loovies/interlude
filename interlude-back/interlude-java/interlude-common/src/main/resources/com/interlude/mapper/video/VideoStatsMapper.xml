		</foreach>
		on DUPLICATE key update
		video_id = VALUES(video_id),play_count = VALUES(play_count),like_count = VALUES(like_count),danmu_count = VALUES(danmu_count),comment_count = VALUES(comment_count),collect_count = VALUES(collect_count),share_count = VALUES(share_count),unconcern_count = VALUES(unconcern_count),last_play_time = VALUES(last_play_time),hot_score = VALUES(hot_score),update_time = VALUES(update_time)
