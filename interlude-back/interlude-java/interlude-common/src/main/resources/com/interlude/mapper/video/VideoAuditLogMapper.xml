<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interlude.mapper.video.VideoAuditLogMapper">
	<!--实体映射-->
	<resultMap id="base_result_map" type="com.interlude.entity.po.video.VideoAuditLog">
		<!---->
		<id column="log_id" property="logId"/>
		<!---->
		<result column="video_id" property="videoId"/>
		<!--老状态 “1:待处理”、“2:已批准”、“3:已拒绝”、“4:已取消”-->
		<result column="old_status" property="oldStatus"/>
		<!--新状态 “1:待处理”、“2:已批准”、“3:已拒绝”、“4:已取消”-->
		<result column="new_status" property="newStatus"/>
		<!--审计员编号-->
		<result column="auditor_id" property="auditorId"/>
		<!--行动评论-->
		<result column="action_comment" property="actionComment"/>
		<!---->
		<result column="create_time" property="createTime"/>
	</resultMap>
	<!--通用测序结果列-->
	<sql id="base_column_list">
		log_id,video_id,old_status,new_status,auditor_id,action_comment,create_time
	</sql>


	<!--基础条件查询-->
	<sql id="base_query_condition">
		<if test="query.logId != null">
			and log_id = #{query.logId} 
		</if>
		<if test="query.videoId != null">
			and video_id = #{query.videoId} 
		</if>
		<if test="query.oldStatus != null">
			and old_status = #{query.oldStatus} 
		</if>
		<if test="query.newStatus != null">
			and new_status = #{query.newStatus} 
		</if>
		<if test="query.auditorId != null">
			and auditor_id = #{query.auditorId} 
		</if>
		<if test="query.actionComment != null and query.actionComment != ''">
			and action_comment = #{query.actionComment} 
		</if>
		<if test="query.createTime != null">
			and create_time = #{query.createTime} 
		</if>
	</sql>

	<!--扩展的条件查询-->
	<sql id="base_query_condition_extend">
		<if test="query.actionCommentFuzzy != null and query.actionCommentFuzzy != ''">
			and action_comment like concat('%', #{query.actionCommentFuzzy}, '%')
		</if>
		<if test="query.createTimeStart != null and query.createTimeStart != ''">
			<![CDATA[ and create_time >= str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEnd != null and query.createTimeEnd != ''">
			<![CDATA[ and create_time < date_sub(str_to_date(#{query.createTimeEnd}, '%Y-%m-%d'),interval -1 day) ]]>
		</if>
	</sql>

	<!--扩展的查询条件-->
	<sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
	</sql>

	<!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM video_audit_log <include refid="query_condition"/>
		<if test="query.orderBy != null"> order by ${query.orderBy} </if>
		<if test="query.simplePage != null"> limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>

	<!--查询数量-->
	<select id="selectCount" resultType="java.lang.Integer">
		SELECT count(1) FROM video_audit_log <include refid="query_condition"/>
	</select>

	<!--插入(匹配有值的字段)-->
	<insert id="insert" parameterType="com.interlude.entity.po.video.VideoAuditLog">
		INSERT INTO video_audit_log
		<trim  prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.logId != null">
				log_id,
			</if>
			<if test="bean.videoId != null">
				video_id,
			</if>
			<if test="bean.oldStatus != null">
				old_status,
			</if>
			<if test="bean.newStatus != null">
				new_status,
			</if>
			<if test="bean.auditorId != null">
				auditor_id,
			</if>
			<if test="bean.actionComment != null">
				action_comment,
			</if>
			<if test="bean.createTime != null">
				create_time,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.logId != null">
				#{bean.logId},
			</if>
			<if test="bean.videoId != null">
				#{bean.videoId},
			</if>
			<if test="bean.oldStatus != null">
				#{bean.oldStatus},
			</if>
			<if test="bean.newStatus != null">
				#{bean.newStatus},
			</if>
			<if test="bean.auditorId != null">
				#{bean.auditorId},
			</if>
			<if test="bean.actionComment != null">
				#{bean.actionComment},
			</if>
			<if test="bean.createTime != null">
				#{bean.createTime},
			</if>
		</trim>
	</insert>

	<!-- 插入或者更新 (匹配有值的字段) -->
	<insert id="insertOrUpdate" parameterType="com.interlude.entity.po.video.VideoAuditLog">
		INSERT INTO video_audit_log
		<trim  prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.logId != null">
				log_id,
			</if>
			<if test="bean.videoId != null">
				video_id,
			</if>
			<if test="bean.oldStatus != null">
				old_status,
			</if>
			<if test="bean.newStatus != null">
				new_status,
			</if>
			<if test="bean.auditorId != null">
				auditor_id,
			</if>
			<if test="bean.actionComment != null">
				action_comment,
			</if>
			<if test="bean.createTime != null">
				create_time,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.logId != null">
				#{bean.logId},
			</if>
			<if test="bean.videoId != null">
				#{bean.videoId},
			</if>
			<if test="bean.oldStatus != null">
				#{bean.oldStatus},
			</if>
			<if test="bean.newStatus != null">
				#{bean.newStatus},
			</if>
			<if test="bean.auditorId != null">
				#{bean.auditorId},
			</if>
			<if test="bean.actionComment != null">
				#{bean.actionComment},
			</if>
			<if test="bean.createTime != null">
				#{bean.createTime},
			</if>
		</trim>
		on DUPLICATE key update
		<trim  prefix="" suffix="" suffixOverrides=",">

			<if test="bean.videoId!=null">
				video_id = VALUES(video_id),
			</if>
			<if test="bean.oldStatus!=null">
				old_status = VALUES(old_status),
			</if>
			<if test="bean.newStatus!=null">
				new_status = VALUES(new_status),
			</if>
			<if test="bean.auditorId!=null">
				auditor_id = VALUES(auditor_id),
			</if>
			<if test="bean.actionComment!=null">
				action_comment = VALUES(action_comment),
			</if>
			<if test="bean.createTime!=null">
				create_time = VALUES(create_time),
			</if>
		</trim>
	</insert>

	<!--添加 (批量插入)-->
	<insert id="insertBatch" parameterType="com.interlude.entity.po.video.VideoAuditLog" >
		INSERT INTO video_audit_log(video_id,old_status,new_status,auditor_id,action_comment,create_time)values
		<foreach collection="list" item="item" separator=",">
			(#{item.videoId},#{item.oldStatus},#{item.newStatus},#{item.auditorId},#{item.actionComment},#{item.createTime})
		</foreach>
	</insert>

	<!--批量插入或者更新-->
	<insert id="insertOrUpdateBatch" parameterType="com.interlude.entity.po.video.VideoAuditLog" >
		INSERT INTO video_audit_log(video_id,old_status,new_status,auditor_id,action_comment,create_time)values
		<foreach collection="list" item="item" separator=",">
			(#{item.videoId},#{item.oldStatus},#{item.newStatus},#{item.auditorId},#{item.actionComment},#{item.createTime})
		</foreach>
		on DUPLICATE key update
		log_id = VALUES(log_id),video_id = VALUES(video_id),old_status = VALUES(old_status),new_status = VALUES(new_status),auditor_id = VALUES(auditor_id),action_comment = VALUES(action_comment),create_time = VALUES(create_time)
	</insert>

	<!-- 根据LogId查询 -->
	<select id="selectByLogId" resultMap="base_result_map">
		select <include refid="base_column_list"/> from video_audit_log where log_id=#{logId}
	</select>

    <select id="getVideoIdByNewLogInfo" resultMap="base_result_map">
		select * from video_audit_log where video_id = #{videoId} ORDER BY create_time desc limit 0,1
	</select>

    <!-- 根据LogId更新 -->
	<update id="updateByLogId" parameterType="com.interlude.entity.po.video.VideoAuditLog">
		update video_audit_log
		<set>
			<if test="bean.logId != null" >
				log_id = #{bean.logId},
			</if>
			<if test="bean.videoId != null" >
				video_id = #{bean.videoId},
			</if>
			<if test="bean.oldStatus != null" >
				old_status = #{bean.oldStatus},
			</if>
			<if test="bean.newStatus != null" >
				new_status = #{bean.newStatus},
			</if>
			<if test="bean.auditorId != null" >
				auditor_id = #{bean.auditorId},
			</if>
			<if test="bean.actionComment != null" >
				action_comment = #{bean.actionComment},
			</if>
			<if test="bean.createTime != null" >
				create_time = #{bean.createTime},
			</if>

		</set>
		where log_id=#{logId}
	</update>

	<!-- 根据LogId删除 -->
	<delete id="deleteByLogId">
		delete from video_audit_log where log_id=#{logId}
	</delete>

</mapper>