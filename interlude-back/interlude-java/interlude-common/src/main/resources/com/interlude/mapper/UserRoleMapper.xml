	</sql>

	<!--扩展的条件查询-->
	<sql id="base_query_condition_extend">
		<if test="query.roleNameFuzzy != null and query.roleNameFuzzy != ''">
			and role_name like concat('%', #{query.roleNameFuzzy}, '%')
		</if>
		<if test="query.descriptionFuzzy != null and query.descriptionFuzzy != ''">
			and description like concat('%', #{query.descriptionFuzzy}, '%')
		</if>
		<if test="query.dataScopeFuzzy != null and query.dataScopeFuzzy != ''">
