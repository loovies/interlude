		</if>
		<if test="query.addressFuzzy != null and query.addressFuzzy != ''">
			and u.address like concat('%', #{query.addressFuzzy}, '%')
		</if>
		<if test="query.schoolFuzzy != null and query.schoolFuzzy != ''">
			and u.school like concat('%', #{query.schoolFuzzy}, '%')
		</if>
		<if test="query.personIntroductionFuzzy != null and query.personIntroductionFuzzy != ''">
			and u.person_introduction like concat('%', #{query.personIntroductionFuzzy}, '%')
		</if>
		<if test="query.createTimeStart != null and query.createTimeStart != ''">
			<![CDATA[ and u.create_time >= str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEnd != null and query.createTimeEnd != ''">
			<![CDATA[ and u.create_time < date_sub(str_to_date(#{query.createTimeEnd}, '%Y-%m-%d'),interval -1 day) ]]>
		</if>
		<if test="query.updateTimeStart != null and query.updateTimeStart != ''">
			<![CDATA[ and u.update_time >= str_to_date(#{query.updateTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.updateTimeEnd != null and query.updateTimeEnd != ''">
			<![CDATA[ and u.update_time < date_sub(str_to_date(#{query.updateTimeEnd}, '%Y-%m-%d'),interval -1 day) ]]>
		</if>
		<if test="query.pwdResetTimeStart != null and query.pwdResetTimeStart != ''">
			<![CDATA[ and u.pwd_reset_time >= str_to_date(#{query.pwdResetTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.pwdResetTimeEnd != null and query.pwdResetTimeEnd != ''">
			<![CDATA[ and u.pwd_reset_time < date_sub(str_to_date(#{query.pwdResetTimeEnd}, '%Y-%m-%d'),interval -1 day) ]]>
		</if>
		<if test="query.createByFuzzy != null and query.createByFuzzy != ''">
			and u.create_by like concat('%', #{query.createByFuzzy}, '%')
		</if>
		<if test="query.updateByFuzzy != null and query.updateByFuzzy != ''">
			and u.update_by like concat('%', #{query.updateByFuzzy}, '%')
		</if>
	</sql>

	<!--扩展的查询条件-->
	<sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
	</sql>

	<select id="selectByParam"  resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM user_info u <include refid="query_condition"/>
	</select>

	<!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/>
		<if test="query.roleName != null and query.roleName.size() > 0">
			,r.role_id
		</if>
		FROM user_info u
		<if test="query.roleName != null and query.roleName.size() > 0">
			left join user_role_relation r on u.user_id = r.user_id
		</if>
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
			<if test="query.roleName != null and query.roleName.size() > 0">
				and r.role_id in (<foreach collection="query.roleName" item="item" separator=",">#{item}</foreach>)
			</if>
		</where>

		<if test="query.orderBy != null"> order by ${query.orderBy} </if>
		<if test="query.simplePage != null"> limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>

