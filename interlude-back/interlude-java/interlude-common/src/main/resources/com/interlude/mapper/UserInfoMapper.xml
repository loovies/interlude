	<!--通用测序结果列-->
	<sql id="base_column_list">
		u.user_id,u.email,u.avatar,u.nick_name,u.password,u.sex,u.birthday,u.phone,u.address,u.school,u.person_introduction,u.create_time,u.update_time,u.pwd_reset_time,u.theme,u.create_by,u.update_by,u.enabled
	</sql>


	<!--基础条件查询-->
	<sql id="base_query_condition">
		<if test="query.userId != null and query.userId != ''">
			and u.user_id = #{query.userId}
		</if>
		<if test="query.email != null and query.email != ''">
			and u.email = #{query.email}
		</if>
		<if test="query.avatar != null and query.avatar != ''">
			and u.avatar = #{query.avatar}
		</if>
		<if test="query.nickName != null and query.nickName != ''">
			and u.nick_name = #{query.nickName}
		</if>
		<if test="query.password != null and query.password != ''">
			and u.password = #{query.password}
		</if>
		<if test="query.sex != null">
			and u.sex = #{query.sex}
		</if>
		<if test="query.birthday != null and query.birthday != ''">
			and u.birthday = #{query.birthday}
		</if>
		<if test="query.phone != null and query.phone != ''">
			and u.phone = #{query.phone}
		</if>
		<if test="query.address != null and query.address != ''">
			and u.address = #{query.address}
		</if>
		<if test="query.school != null and query.school != ''">
			and u.school = #{query.school}
		</if>
		<if test="query.personIntroduction != null and query.personIntroduction != ''">
			and u.person_introduction = #{query.personIntroduction}
		</if>
		<if test="query.createTime != null">
			and u.create_time = #{query.createTime}
		</if>
		<if test="query.updateTime != null">
			and u.update_time = #{query.updateTime}
		</if>
		<if test="query.pwdResetTime != null">
			and u.pwd_reset_time = #{query.pwdResetTime}
		</if>
		<if test="query.theme != null">
			and u.theme = #{query.theme}
		</if>
		<if test="query.createBy != null and query.createBy != ''">
			and u.create_by = #{query.createBy}
		</if>
		<if test="query.updateBy != null and query.updateBy != ''">
			and u.update_by = #{query.updateBy}
		</if>
		<if test="query.enabled != null">
			and u.enabled = #{query.enabled}
		</if>
		<if test="query.account != null and query.account != ''">
			and (u.phone = #{query.account} or u.email = #{query.account})
		</if>
		<if test="query.createTimeFormatArray != null and query.createTimeFormatArray.size() > 0">
			and DATE_FORMAT(u.create_time, '%Y-%m-%d') in (<foreach collection="query.createTimeFormatArray" item="item" separator=",">#{item}</foreach>)
		</if>
	</sql>


	<!--扩展的条件查询-->
	<sql id="base_query_condition_extend">
		<if test="query.userIdFuzzy != null and query.userIdFuzzy != ''">
			and u.user_id like concat('%', #{query.userIdFuzzy}, '%')
		</if>
		<if test="query.emailFuzzy != null and query.emailFuzzy != ''">
			and u.email like concat('%', #{query.emailFuzzy}, '%')
		</if>
		<if test="query.avatarFuzzy != null and query.avatarFuzzy != ''">
			and u.avatar like concat('%', #{query.avatarFuzzy}, '%')
		</if>
		<if test="query.nickNameFuzzy != null and query.nickNameFuzzy != ''">
